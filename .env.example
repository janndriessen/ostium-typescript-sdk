# Required for trading operations
PRIVATE_KEY=0x...
RPC_URL=https://arb1.arbitrum.io/rpc

# Set to "true" to run live integration tests (pnpm test:integration)
# Hits real price API and subgraph — read-only, no wallet needed
INTEGRATION=true

# Smoke tests only (pnpm test:smoke)
# Executes real trades on Arbitrum One — requires funded wallet with ETH + USDC
SMOKE_PRIVATE_KEY=0x...
SMOKE_RPC_URL=https://arb1.arbitrum.io/rpc
